# Aplicacion
APP_ENV=development
DEBUG=true

# Base de Datos
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/bot_apuestas
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30

# Bot de Telegram (obtener de @BotFather)
TELEGRAM_BOT_TOKEN=tu_token_del_bot_aqui

# Redis
REDIS_URL=redis://localhost:6379/0

# Seguridad
SECRET_KEY=tu_super_llave_secreta_de_al_menos_32_caracteres
ACCESS_TOKEN_EXPIRE_MINUTES=30

# The Odds API (registrarse en https://the-odds-api.com)
ODDS_API_KEY=tu_api_key_de_odds
ODDS_API_BASE_URL=https://api.the-odds-api.com

# Admin de Telegram (tu user id)
ADMIN_TELEGRAM_ID=##########

# Cron Secret (para proteger los endpoints)
CRON_SECRET=tu_cron_secret_seguro_minimo_16_caracteres

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json