# Aplicación
APP_ENV=development
DEBUG=true

# Base de Datos (PostgreSQL con driver asyncpg)
# Formato: postgresql+asyncpg://usuario:contraseña@host:puerto/base_de_datos
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/bot_apuestas
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30

# Bot de Telegram (Obténlo de @BotFather)
TELEGRAM_BOT_TOKEN=tu_token_del_bot_aqui

# Configuración de Webhook (Opcional - para producción)
# TELEGRAM_WEBHOOK_URL=https://tudominio.com/webhook/telegram
# TELEGRAM_WEBHOOK_SECRET=tu_token_secreto_del_webhook
# TELEGRAM_ALLOWED_UPDATES=["message", "callback_query", "inline_query"]

# Redis (para caché, límite de velocidad, sesiones)
REDIS_URL=redis://localhost:6379/0

# Seguridad
# Generar con: openssl rand -hex 32
SECRET_KEY=tu_super_llave_secreta_de_al_menos_32_caracteres
ACCESS_TOKEN_EXPIRE_MINUTES=30

# APIs Externas (Opcional - para datos de cuotas deportivas)
# ODDS_API_KEY=tu_api_key_de_odds
# ODDS_API_BASE_URL=https://api.the-odds-api.com

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json